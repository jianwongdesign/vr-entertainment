# Copy this file to .env and fill in the Hostinger SSH values.
# Do not commit .env.

# Hostinger usually shows this in hPanel > Websites > Manage > SSH Access.
HOSTINGER_SSH_HOST=
HOSTINGER_SSH_USER=
HOSTINGER_SSH_PORT=65002

# Optional. Leave blank to use the default SSH key or password prompt.
SSH_KEY_PATH=

# Common Hostinger WordPress path:
# /home/USERNAME/domains/overworld.com.sg/public_html
REMOTE_WP_PATH=

# Local folder used by the sync scripts.
LOCAL_WP_CONTENT=wordpress/wp-content
